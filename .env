# 是否开启 mock (生产环境不使用 Mock，连真实后端)
VITE_USE_MOCK=false

# App title
VITE_GLOB_APP_TITLE=DGKJ支付平台

# Basic interface address - 指向云端后端服务器
VITE_GLOB_API_URL=https://dghs.gddogootech.com

# File upload address
VITE_GLOB_UPLOAD_URL=/upload

# Interface prefix - 统一使用 /basic-api 前缀
VITE_GLOB_API_URL_PREFIX=
