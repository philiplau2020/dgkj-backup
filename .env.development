# 是否开启 mock - 永远禁用，使用真实后端
VITE_USE_MOCK=false

# public path
VITE_PUBLIC_PATH=/

# App title
VITE_GLOB_APP_TITLE=DGKJ支付平台

# Basic interface address - 指向云端后端（开发时直接连真实后端）
VITE_GLOB_API_URL=http://dghs.gddogootech.com

# File upload address
VITE_GLOB_UPLOAD_URL=/upload

# Interface prefix
VITE_GLOB_API_URL_PREFIX=
